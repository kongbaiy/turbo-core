{
    "name": "cloud-core",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@9.0.5",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{js,ts,jsx,tsx,css,scss,html,md}\"",
        "check-types": "turbo run check-types",
        "preinstall": "npx only-allow pnpm",
        "postinstall": "husky",
        "prepare": "husky",
        "lint:eslint": "eslint . --fix",
        "lint:stylelint": "stylelint \"**/*.{css,scss}\" --fix",
        "clone": "sh git-clone.sh"
    },
    "dependencies": {
        "@ant-design/icons": "^6.2.3",
        "@ant-design/pro-components": "^3.0.0-beta.1",
        "antd": "^6.4.3",
        "core-js": "^3.49.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router-dom": "^7.15.1"
    },
    "devDependencies": {
        "@repo/antd-theme": "workspace:*",
        "@repo/commitlint-config": "workspace:*",
        "@repo/eslint-config": "workspace:*",
        "@repo/react-components": "workspace:*",
        "@repo/stylelint-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@repo/unocss-config": "workspace:*",
        "@repo/vite-config": "workspace:*",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "postcss-html": "^1.8.1",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "turbo": "^2.9.14",
        "typescript": "5.9.2",
        "unbuild": "^3.6.1"
    },
    "engines": {
        "node": ">=18"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "lint-staged": {
        "*.{vue,js,jsx}": "eslint --fix --max-warnings 0 --no-warn-ignored",
        "*.{json,md}": "eslint --fix --max-warnings 0 --no-warn-ignored",
        "*.{css,scss}": "stylelint --fix",
        "*.{ts,tsx}": "bash -c './node_modules/.bin/tsc --noEmit -p tsconfig.json'"
    }
}