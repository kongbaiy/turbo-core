{
    "editor.formatOnSave": true,
    "npm.packageManager": "pnpm",

    // Auto fix
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "never",
        "source.fixAll.stylelint": "explicit"
    },

    // eslint 配置
    "eslint.format.enable": true,
    "eslint.probe": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html",
        "vue",
        "markdown",
        "json",
        "jsonc"
    ],
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html",
        "vue",
        "markdown",
        "json",
        "jsonc"
    ],

    // stylelint 配置
    "stylelint.enable": true,
    "stylelint.validate": [
        "css",
        "less",
        "postcss",
        "scss",
        "vue",
        "sass",
        "html",
        "react",
        "jsx",
        "tsx"
    ],

    // unocss 配置
    "scss.lint.unknownAtRules": "ignore",
    "css.lint.unknownAtRules": "ignore",
    "less.lint.unknownAtRules": "ignore",

    "files.eol": "\n",

    "cSpell.words": [
        "commitlint",
        "cssinjs",
        "excludesfile",
        "njsproj",
        "ntvs",
        "PREFIXS",
        "qiankun",
        "serviceworker",
        "Siderbar",
        "unocss",
        "unplugin",
        "Vercel",
        "vite",
        "Wechat"
    ],

    // 格式化配置
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}
